[gd_scene load_steps=2 format=3 uid="uid://gamescene01"]

[ext_resource type="Script" path="res://scripts/game.gd" id="1_script"]

[node name="Game" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_script")

[node name="Margin" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/margin_left = 16
theme_override_constants/margin_top = 16
theme_override_constants/margin_right = 16
theme_override_constants/margin_bottom = 16

[node name="VBox" type="VBoxContainer" parent="Margin"]
layout_mode = 2
theme_override_constants/separation = 10

[node name="Toolbar" type="HBoxContainer" parent="Margin/VBox"]
layout_mode = 2
theme_override_constants/separation = 12

[node name="BtnLevel" type="Button" parent="Margin/VBox/Toolbar"]
layout_mode = 2
text = "返回选关"

[node name="BtnRetry" type="Button" parent="Margin/VBox/Toolbar"]
layout_mode = 2
disabled = true
text = "重试本关"

[node name="Status" type="Label" parent="Margin/VBox/Toolbar"]
layout_mode = 2
size_flags_horizontal = 3
text = "进行中"

[node name="MineLabel" type="Label" parent="Margin/VBox"]
layout_mode = 2
text = "剩余标记/雷: 0"

[node name="Scroll" type="ScrollContainer" parent="Margin/VBox"]
layout_mode = 2
size_flags_vertical = 3

[node name="BoardGrid" type="GridContainer" parent="Margin/VBox/Scroll"]
layout_mode = 2
theme_override_constants/h_separation = 2
theme_override_constants/v_separation = 2

[connection signal="pressed" from="Margin/VBox/Toolbar/BtnLevel" to="." method="_on_level_select_pressed"]
[connection signal="pressed" from="Margin/VBox/Toolbar/BtnRetry" to="." method="_on_retry_pressed"]
